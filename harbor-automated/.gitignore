# Build artifacts
bin/

# Packaged charts (CI generates these)
packages/
*.tgz
# But keep harbor-helm subchart dependencies committed (CI doesn't run helm dep update)
!harbor-helm/charts/*.tgz

# Temporary files
*.tmp
*.log
*.backup
*.old

# Note: harbor-helm/ is now committed (built by CI)
# This ensures declarative GitOps workflow
